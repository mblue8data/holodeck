def _ensure_local_venv_site_packages():
    holo_root = Path(__file__).resolve().parent
    venv_root = holo_root / "holo_env"
    if not venv_root.exists():
        return

    lib_root = venv_root / "lib"
    if not lib_root.exists():
        return

    for site_packages in lib_root.glob("python*/site-packages"):
        sys.path.insert(0, str(site_packages))
        break


_ensure_local_venv_site_packages()

